---
const {
  title,
  description,
  canonical = 'https://startups.techritual.com/',
  ogImage = 'https://www.techritual.com/wp-content/uploads/2025/03/techritual_logo_v.webp'
} = Astro.props;
---
<!doctype html>
<html lang="zh-HK">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="icon" href="https://www.techritual.com/favicon.ico" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="website" />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="TechRitual Startups" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- AdSense auto-ads (inherits from techritual.com publisher account) -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3665735472523700" crossorigin="anonymous"></script>

<style is:global>
*,*::before,*::after{box-sizing:border-box}
html{-webkit-text-size-adjust:100%}
body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans","PingFang TC","Microsoft JhengHei",sans-serif;background:#f5f5f7;color:#1a1a2e;line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:#ea4157;text-decoration:none}
a:hover{text-decoration:underline}

.header{background:#ea4157;padding:14px 0}
.header-inner{max-width:1200px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.header-logo img{height:30px;display:block}
.header-nav{display:flex;gap:18px;flex-wrap:wrap}
.header-nav a{color:rgba(255,255,255,.9);font-size:14px;font-weight:500}
.header-nav a:hover{color:#fff;text-decoration:none}

.hero{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);color:#fff;padding:60px 20px 50px;text-align:center}
.hero h1{font-size:36px;font-weight:800;margin:0 0 14px;line-height:1.25;max-width:900px;margin-left:auto;margin-right:auto}
.hero .sub{font-size:17px;color:#b0b0c8;max-width:680px;margin:0 auto 18px}
.hero .stats{display:inline-flex;align-items:center;gap:16px;background:rgba(255,255,255,.08);padding:10px 22px;border-radius:30px;font-size:14px;color:#e0e0e8;margin-top:6px;flex-wrap:wrap;justify-content:center}
.hero .stats strong{color:#fff;font-weight:700;font-size:20px}
@media(max-width:600px){.hero h1{font-size:28px}.hero .sub{font-size:15px}}

.wrap{max-width:1200px;margin:0 auto;padding:0 20px}

.intro{background:#fff;border-radius:16px;padding:28px 32px;margin:-30px auto 32px;max-width:1140px;box-shadow:0 2px 16px rgba(0,0,0,.06);position:relative;z-index:1}
.intro h2{font-size:18px;margin:0 0 10px;color:#1a1a2e}
.intro p{font-size:14px;color:#555;margin:8px 0;line-height:1.75}
@media(max-width:600px){.intro{padding:20px 22px;margin:-20px 16px 24px}}

.filters{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin:0 0 24px}
.filter{padding:8px 16px;border:1px solid #e0e0e0;border-radius:20px;background:#fff;font-size:14px;cursor:pointer;color:#666;font-family:inherit;transition:all .2s}
.filter:hover{border-color:#ea4157;color:#ea4157}
.filter.active{background:#ea4157;border-color:#ea4157;color:#fff;font-weight:600}

.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}
@media(max-width:880px){.grid{grid-template-columns:repeat(2,1fr);gap:14px}}
@media(max-width:520px){.grid{grid-template-columns:1fr}}

.card{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,.06);transition:transform .15s,box-shadow .15s;display:flex;flex-direction:column}
.card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
.card a{display:flex;flex-direction:column;flex:1;color:inherit;text-decoration:none}
.card a:hover{text-decoration:none}
.card-img{width:100%;aspect-ratio:16/9;object-fit:cover;background:#f0f0f0;display:block;border-bottom:1px solid #f0f0f0}
.card-img-placeholder{width:100%;aspect-ratio:16/9;background:linear-gradient(135deg,#1a1a2e,#16213e);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);font-size:48px}
.card-body{padding:16px 18px 18px;display:flex;flex-direction:column;flex:1}
.card-body h2{font-size:17px;font-weight:700;margin:0 0 6px;color:#1a1a2e;line-height:1.35}
.card-body p{font-size:14px;color:#666;margin:0;line-height:1.55;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-meta{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px;font-size:11px}
.card-cat{background:#fef2f2;color:#ea4157;padding:3px 9px;border-radius:8px;font-weight:600}
.card-region{background:#f0f0f0;color:#666;padding:3px 9px;border-radius:8px}
.card-dev{font-size:11px;color:#999;margin-top:8px;font-style:italic}

.empty{text-align:center;padding:60px 20px;color:#888;background:#fff;border-radius:14px;margin-bottom:32px}
.empty h3{font-size:18px;color:#1a1a2e;margin:0 0 10px}
.empty p{font-size:14px;margin:6px 0}

.cta{background:linear-gradient(135deg,#ea4157,#d13649);color:#fff;border-radius:16px;padding:42px 28px;text-align:center;margin:48px 0}
.cta h2{font-size:26px;font-weight:800;margin:0 0 8px;color:#fff}
.cta p{font-size:15px;color:rgba(255,255,255,.92);margin:0 0 22px;max-width:520px;margin-left:auto;margin-right:auto}
.cta-btn{display:inline-block;background:#fff;color:#ea4157;padding:14px 30px;border-radius:30px;font-size:16px;font-weight:700;text-decoration:none;transition:transform .15s}
.cta-btn:hover{transform:translateY(-2px);text-decoration:none;color:#ea4157}
@media(max-width:600px){.cta{padding:30px 22px;margin:32px 0}.cta h2{font-size:22px}}

.footer{background:#1a1a2e;color:#888;padding:32px 20px;text-align:center;font-size:13px;margin-top:24px}
.footer a{color:#b0b0c8}
.footer a:hover{color:#fff}
.footer-meta{margin-top:8px;font-size:12px;color:#666}
</style>
</head>
<body>
<header class="header">
  <div class="header-inner">
    <a href="https://www.techritual.com" class="header-logo" rel="noopener">
      <img src="https://www.techritual.com/wp-content/uploads/2025/03/techritual_logo_v.webp" alt="TechRitual" />
    </a>
    <nav class="header-nav">
      <a href="https://www.techritual.com">主站</a>
      <a href="/submit">免費投稿</a>
      <a href="/">Startups</a>
    </nav>
  </div>
</header>

<slot />

<footer class="footer">
  <div>
    © 2026 <a href="https://www.techritual.com">TechRitual.com</a> — 專注 Mobile | Wearable | AI
  </div>
  <div class="footer-meta">
    <slot name="footer-meta" />
  </div>
</footer>
</body>
</html>
